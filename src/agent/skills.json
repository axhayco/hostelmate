{
  "personas": {
    "Student": {
      "role": "Hostel Resident / Student",
      "tools": [
        {
          "name": "RequestLeave",
          "description": "Submit a leave request for out-of-campus travel or going home.",
          "parameters": {
            "type": "object",
            "properties": {
              "startDate": {
                "type": "string",
                "format": "date",
                "description": "The date the student plans to leave."
              },
              "endDate": {
                "type": "string",
                "format": "date",
                "description": "The date the student plans to return."
              },
              "reason": {
                "type": "string",
                "description": "Reason for the leave."
              }
            },
            "required": ["startDate", "endDate", "reason"]
          }
        },
        {
          "name": "GetMessMenu",
          "description": "Retrieve the mess menu for a specific day or meal.",
          "parameters": {
            "type": "object",
            "properties": {
              "day": {
                "type": "string",
                "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday", "Today", "Tomorrow"],
                "description": "The day to get the menu for."
              },
              "mealType": {
                "type": "string",
                "enum": ["Breakfast", "Lunch", "Snacks", "Dinner", "All"],
                "description": "Specific meal time, or 'All' for the full day menu."
              }
            },
            "required": ["day", "mealType"]
          }
        },
        {
          "name": "CheckElectricityBalance",
          "description": "Check the prepaid electricity meter balance for the student's room.",
          "parameters": {
            "type": "object",
            "properties": {
              "roomNumber": {
                "type": "string",
                "description": "The room number to check. Usually inferred from user context."
              }
            },
            "required": ["roomNumber"]
          }
        }
      ]
    },
    "Owner": {
      "role": "Hostel Owner / Administrator",
      "tools": [
        {
          "name": "BroadcastNotice",
          "description": "Send a mass notification to all residents in a specific hostel or globally.",
          "parameters": {
            "type": "object",
            "properties": {
              "hostelId": {
                "type": "string",
                "description": "Target hostel ID, or 'All' for all properties."
              },
              "message": {
                "type": "string",
                "description": "The content of the notice to send."
              },
              "urgency": {
                "type": "string",
                "enum": ["Low", "Normal", "High", "Critical"],
                "description": "Importance level of the notice."
              }
            },
            "required": ["hostelId", "message", "urgency"]
          }
        },
        {
          "name": "ApproveLeave",
          "description": "Approve or reject a student's pending leave request.",
          "parameters": {
            "type": "object",
            "properties": {
              "leaveId": {
                "type": "string",
                "description": "The ID of the leave request."
              },
              "status": {
                "type": "string",
                "enum": ["Approved", "Rejected"],
                "description": "Decision on the leave request."
              },
              "comments": {
                "type": "string",
                "description": "Optional comments from the owner."
              }
            },
            "required": ["leaveId", "status"]
          }
        },
        {
          "name": "CheckOccupancyStats",
          "description": "Retrieve current occupancy, vacant beds, and revenue analytics for a hostel.",
          "parameters": {
            "type": "object",
            "properties": {
              "hostelId": {
                "type": "string",
                "description": "The ID of the hostel to check stats for."
              }
            },
            "required": ["hostelId"]
          }
        }
      ]
    }
  }
}
